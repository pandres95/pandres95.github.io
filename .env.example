# Ghost blog is fetched via public RSS — no API key needed
# blog.pablodorado.com/rss/

# Last.fm API key — get from https://www.last.fm/api/account/create (public, safe for client)
PUBLIC_LASTFM_API_KEY=

# GitHub personal access token (optional — avoids rate limits for GitHub repos widget)
GITHUB_TOKEN=

# Cloudflare Pages deployment (used in GitHub Actions only)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
