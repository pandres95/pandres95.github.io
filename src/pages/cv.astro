---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const experience = [
  {
    company: 'Bloque',
    role: 'Blockchain Engineer',
    period: '2026 – Present',
    summary: 'Contributing to the integration of Polkadot-based blockchain infrastructure into Bloque\'s crypto-native financial platform. Work spans on-chain transaction flows, stablecoin rails, and the underlying protocol layer that powers card payments, remittances, and treasury operations across Latin America.',
  },
  {
    company: 'Virto Network',
    role: 'Senior Software Engineer',
    period: '2022 – Present',
    summary: 'Building decentralised services enabling communities to operate as DAOs. Developing tooling for dCommerce infrastructure on Polkadot, driving consulting for builder integrations.',
  },
  {
    company: 'Cubo.land',
    role: 'Technical Consultant / Senior Software Engineer',
    period: '2022 – 2024',
    summary: 'Architected the product\'s Web3 layer for Latin America\'s first real estate-backed ETF (CUBO). Built and maintained off-chain/on-chain services and the Platform API.',
  },
  {
    company: 'Bloque',
    role: 'Senior Software Engineer',
    period: '2022',
    summary: 'Led design and deployment of core revenue services for a Web3 fintech enabling Latin American commerce to save in stablecoins.',
  },
  {
    company: 'Valiu',
    role: 'Lead Fullstack Engineer',
    period: '2019 – 2020',
    summary: 'YC S\'19. Designed microservices architecture, built AML/KYC service with OCR, and managed company infrastructure for a crypto-backed remittance platform.',
  },
];

const skills = ['Rust', 'Substrate', 'WASM', 'TypeScript', 'Polkadot / XCM', 'Distributed Systems', 'Compiler Design', 'DevOps / CI-CD', 'Microservices', 'Node.js'];

const languages = [
  { lang: 'Spanish', level: 'Native' },
  { lang: 'English', level: 'C2 Proficient' },
  { lang: 'French', level: 'Limited Working' },
];
---

<BaseLayout title="CV — Pablo Dorado" description="Curriculum Vitae of Pablo Dorado — Systems Researcher & Blockchain Architect">
  <Header activePage="cv" />

  <!-- ── PRINT-ONLY LAYOUT ── -->
  <div id="cv-print">
    <div class="p-header">
      <div>
        <h1 class="p-name">Pablo Dorado</h1>
        <p class="p-title">Systems Researcher &amp; Blockchain Architect · Polkadot Fellowship</p>
      </div>
      <div class="p-contacts">
        hola@pablodorado.com<br/>
        pablodorado.com · github.com/pandres95<br/>
        linkedin.com/in/pandres95<br/>
        Bogotá, Colombia
      </div>
    </div>

    <p class="p-section-title">Profile</p>
    <p class="p-summary">
      Blockchain Engineer and Development Tools Researcher with 12+ years in software development,
      3 dedicated to blockchain infrastructure. Polkadot Blockchain Academy alumnus and active Member
      of the Polkadot Fellowship. Specialises in runtime development, distributed systems, compiler
      design, and protocol-level architecture. Led initiatives that reduced time-to-market by 96.9%
      through DevOps transformation.
    </p>

    <p class="p-section-title">Technical Skills</p>
    <ul class="p-skills-grid">
      {[
        ['Rust', '●●●●●'],
        ['Substrate / Polkadot SDK', '●●●●●'],
        ['TypeScript / Node.js', '●●●●○'],
        ['WASM / Runtime Dev', '●●●●●'],
        ['Distributed Systems', '●●●●●'],
        ['Compiler Design', '●●●●○'],
        ['DevOps / CI-CD', '●●●●○'],
        ['Microservices', '●●●●●'],
      ].map(([skill, dots]) => (
        <li>
          <span class="p-skill-label">{skill}</span>
          <span class="p-skill-dots">{dots}</span>
        </li>
      ))}
    </ul>

    <div class="p-two-col" style="margin-top: 8px;">
      <div>
        <p class="p-section-title">Languages</p>
        <ul class="p-side-list">
          <li><span class="p-side-key">Spanish</span><span class="p-side-val">Native</span></li>
          <li><span class="p-side-key">English</span><span class="p-side-val">C2 Proficient (EF SET 78/100)</span></li>
          <li><span class="p-side-key">French</span><span class="p-side-val">Limited Working</span></li>
        </ul>
      </div>
      <div>
        <p class="p-section-title">Distinctions</p>
        <ul class="p-side-list">
          <li><span class="p-side-key">Polkadot Fellowship</span><span class="p-side-val">Proficient Member</span></li>
          <li><span class="p-side-key">Maratón ACIS/REDIS XXVII</span><span class="p-side-val">Honorable Mention</span></li>
        </ul>
      </div>
    </div>

    <p class="p-section-title">Experience</p>

    {experience.map(({ company, role, period, summary }) => (
      <div class="p-job">
        <div class="p-job-header">
          <p class="p-company">{company}</p>
          <span class="p-period">{period}</span>
        </div>
        <p class="p-role">{role}</p>
        <p class="p-desc">{summary}</p>
      </div>
    ))}

    <p class="p-section-title">Education</p>

    <div class="p-edu">
      <span class="p-edu-name">Universidad Nacional de Colombia</span>
      <span class="p-edu-degree">B.Sc. Computer Science</span>
      <span class="p-edu-year">2018</span>
    </div>
    <div class="p-edu">
      <span class="p-edu-name">Polkadot Blockchain Academy</span>
      <span class="p-edu-degree">Computer Programming, Specific Applications</span>
      <span class="p-edu-year">2023</span>
    </div>
  </div>

  <!-- ── SCREEN LAYOUT ── -->
  <main id="cv-screen" class="max-w-[1280px] mx-auto px-8 py-8">

    <!-- Print button — hidden on print -->
    <div class="flex justify-end mb-6 print:hidden">
      <button
        onclick="window.print()"
        class="bg-primary text-on-primary-fixed neobrutal-border neobrutal-shadow px-5 py-2 font-mono text-sm font-semibold uppercase rounded hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[2px_2px_0px_0px_#000] transition-all inline-flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[18px]">print</span>
        PRINT / EXPORT_PDF
      </button>
    </div>

    <!-- CV Sheet -->
    <div
      id="cv-sheet"
      class="bg-surface-container neobrutal-border neobrutal-shadow rounded-lg overflow-hidden print:border-0 print:shadow-none print:rounded-none"
    >
      <!-- Header strip -->
      <div class="bg-surface-container-lowest px-8 py-6 border-b-2 border-outline-variant print:border-black print:bg-white print:text-black">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
          <div>
            <h1 class="font-mono text-4xl font-black tracking-tighter text-on-surface uppercase print:text-black">
              PABLO DORADO
            </h1>
            <p class="font-mono text-sm text-primary mt-1 print:text-black">
              Systems Researcher &amp; Blockchain Architect · Polkadot Fellowship
            </p>
          </div>
          <div class="font-mono text-xs text-on-surface-variant space-y-0.5 md:text-right print:text-black">
            <p>hola@pablodorado.com</p>
            <p>pablodorado.com</p>
            <p>linkedin.com/in/pandres95</p>
            <p>github.com/pandres95</p>
            <p>Bogotá, Colombia</p>
          </div>
        </div>
      </div>

      <!-- Body: two columns -->
      <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] print:grid-cols-[220px_1fr] divide-y-2 md:divide-y-0 md:divide-x-2 divide-outline-variant print:divide-black">

        <!-- Left column -->
        <aside class="p-6 print:p-4 flex flex-col gap-6 bg-surface-container-low print:bg-white">

          <!-- Summary -->
          <section>
            <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-3 print:text-gray-500">SUMMARY</h2>
            <p class="text-sm text-on-surface-variant leading-relaxed print:text-gray-700">
              Blockchain Engineer and Development Tools Researcher with 12+ years in software development,
              3 dedicated to blockchain infrastructure. PBA alumnus. Specialises in runtime development,
              distributed systems, and protocol-level architecture.
            </p>
          </section>

          <!-- Skills -->
          <section>
            <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-3 print:text-gray-500">EXPERTISE</h2>
            <div class="flex flex-wrap gap-1.5">
              {skills.map((s) => (
                <span class="border border-outline px-2 py-0.5 font-mono text-[10px] text-on-surface uppercase rounded print:border-gray-400 print:text-gray-700">
                  {s}
                </span>
              ))}
            </div>
          </section>

          <!-- Languages -->
          <section>
            <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-3 print:text-gray-500">LANGUAGES</h2>
            <ul class="space-y-1.5">
              {languages.map(({ lang, level }) => (
                <li class="flex justify-between items-baseline">
                  <span class="font-mono text-xs text-on-surface print:text-black">{lang}</span>
                  <span class="font-mono text-[10px] text-on-surface-variant print:text-gray-500">{level}</span>
                </li>
              ))}
            </ul>
          </section>

          <!-- Education -->
          <section>
            <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-3 print:text-gray-500">EDUCATION</h2>
            <div class="space-y-3">
              <div>
                <p class="font-mono text-xs font-semibold text-on-surface print:text-black">Polkadot Blockchain Academy</p>
                <p class="font-mono text-[10px] text-on-surface-variant print:text-gray-500">Jul – Aug 2023</p>
              </div>
              <div>
                <p class="font-mono text-xs font-semibold text-on-surface print:text-black">Universidad Nacional de Colombia</p>
                <p class="font-mono text-[10px] text-primary print:text-gray-700">B.Sc. Computer Science</p>
                <p class="font-mono text-[10px] text-on-surface-variant print:text-gray-500">2018</p>
              </div>
            </div>
          </section>

          <!-- Certifications & Awards -->
          <section>
            <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-3 print:text-gray-500">CERTS & AWARDS</h2>
            <ul class="space-y-2">
              <li>
                <p class="font-mono text-xs text-on-surface print:text-black">EF SET C2 Proficient</p>
                <p class="font-mono text-[10px] text-on-surface-variant print:text-gray-500">78/100</p>
              </li>
              <li>
                <p class="font-mono text-xs text-on-surface print:text-black">Honorable Mention</p>
                <p class="font-mono text-[10px] text-on-surface-variant print:text-gray-500">XXVII Maratón Nacional Programación ACIS/REDIS</p>
              </li>
            </ul>
          </section>

        </aside>

        <!-- Right column: Experience -->
        <div class="p-6 print:p-4 bg-surface-container print:bg-white">
          <h2 class="font-mono text-xs uppercase tracking-widest text-tertiary mb-4 print:text-gray-500">EXPERIENCE</h2>
          <div class="space-y-5">
            {experience.map(({ company, role, period, summary }) => (
              <div class="border-b border-outline-variant pb-5 last:border-0 last:pb-0 print:border-gray-200">
                <div class="flex justify-between items-baseline gap-4 mb-1">
                  <span class="font-mono text-sm font-bold text-on-surface print:text-black">{company}</span>
                  <span class="font-mono text-xs text-tertiary whitespace-nowrap shrink-0 print:text-gray-500">{period}</span>
                </div>
                <p class="font-mono text-xs text-primary mb-2 print:text-gray-600">{role}</p>
                <p class="text-sm text-on-surface-variant leading-relaxed print:text-gray-700">{summary}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

  </main><!-- end #cv-screen -->

  <Footer />
</BaseLayout>

<script>
  const prev = document.title;
  window.addEventListener('beforeprint', () => { document.title = 'Pablo_Dorado_CV'; });
  window.addEventListener('afterprint',  () => { document.title = prev; });
</script>

<style is:global>
  /* ── SCREEN: hide print layout ── */
  #cv-print { display: none; }

  /* ── PRINT ── */
  @media print {
    /* hide everything except the print layout */
    header, footer, #cv-screen { display: none !important; }
    main { padding: 0 !important; }
    body { background: white !important; }

    #cv-print { display: block; }

    @page {
      size: A4;
      margin: 0;
    }

    /* Print layout styles */
    #cv-print {
      font-family: "Georgia", "Times New Roman", serif;
      font-size: 12.5px;
      line-height: 1.35;
      color: #222;
      width: 210mm;
      min-height: 297mm;
      padding: 22mm 18mm 18mm;
      box-sizing: border-box;
      text-align: left;
    }

    .p-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 2px solid #ccc;
      padding-bottom: 8px;
      margin-bottom: 10px;
      gap: 20px;
    }

    .p-name {
      font-family: "Georgia", serif;
      font-size: 24px;
      font-weight: bold;
      margin: 0 0 2px 0;
      color: #000;
      letter-spacing: -0.5px;
    }

    .p-title {
      font-size: 13px;
      color: #555;
      margin: 0;
    }

    .p-contacts {
      font-size: 11px;
      color: #444;
      text-align: right;
      line-height: 1.6;
    }

    .p-contacts a { color: #444; text-decoration: none; }

    .p-section-title {
      font-family: "Georgia", serif;
      font-size: 12px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #000;
      border-bottom: 1px solid #ccc;
      margin: 10px 0 5px 0;
      padding-bottom: 2px;
    }

    .p-summary {
      font-size: 12.5px;
      color: #333;
      margin: 0 0 2px 0;
    }

    /* Skills two-column grid */
    .p-skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px 24px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .p-skills-grid li {
      font-size: 12px;
      display: flex;
      justify-content: space-between;
      border-bottom: 1px dotted #eee;
      padding: 1px 0;
    }

    .p-skill-label { color: #222; }
    .p-skill-dots { color: #999; letter-spacing: 1px; font-size: 11px; }

    /* Languages + info side by side */
    .p-two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 24px;
    }

    /* Experience entries */
    .p-job {
      margin-bottom: 7px;
    }

    .p-job-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .p-company {
      font-family: "Georgia", serif;
      font-weight: bold;
      font-size: 13px;
      color: #000;
      margin: 0;
    }

    .p-period {
      font-size: 11px;
      color: #666;
      white-space: nowrap;
    }

    .p-role {
      font-size: 11.5px;
      color: #555;
      font-style: italic;
      margin: 1px 0 3px 0;
    }

    .p-desc {
      font-size: 12px;
      color: #333;
      margin: 0;
    }

    /* Education */
    .p-edu {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 4px;
    }

    .p-edu-name { font-weight: bold; font-size: 12.5px; color: #000; }
    .p-edu-degree { font-size: 11.5px; color: #555; font-style: italic; }
    .p-edu-year { font-size: 11px; color: #777; }

    /* Side items */
    .p-side-list {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 12px;
    }

    .p-side-list li {
      display: flex;
      justify-content: space-between;
      padding: 1px 0;
      border-bottom: 1px dotted #eee;
    }

    .p-side-key { color: #222; }
    .p-side-val { color: #666; font-style: italic; }
  }
</style>
