---
const year = new Date().getFullYear();
const links = [
  { href: 'https://github.com/pandres95', label: 'GitHub' },
  { href: 'https://linkedin.com/in/pandres95', label: 'LinkedIn' },
  { href: 'https://dev.to/pandres95', label: 'dev.to' },
  { href: 'https://pandres95.github.io', label: 'SourceCode' },
];
---

<footer class="bg-surface-container-lowest border-t-2 border-outline-variant mt-16">
  <div class="flex flex-col md:flex-row justify-between items-center w-full px-8 py-6 max-w-[1280px] mx-auto gap-4">
    <div class="font-mono text-xl font-black text-on-surface uppercase tracking-tight">
      PABLO DORADO
    </div>

    <div class="flex flex-wrap justify-center gap-6 items-center">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-sm text-on-surface-variant opacity-80 hover:text-primary hover:opacity-100 transition-all"
        >
          {label}
        </a>
      ))}
    </div>

    <div class="font-mono text-xs text-tertiary border border-outline-variant px-2 py-1 rounded text-center">
      v2.0.{year} // ARCHITECTURAL_INTEGRITY_VERIFIED
    </div>
  </div>
</footer>
