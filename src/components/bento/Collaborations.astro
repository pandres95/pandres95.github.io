---
const collaborations = [
  {
    name: 'Bloque',
    role: 'Systems Architecture',
    href: 'https://bloque.app',
    description: 'Crypto-native financial infrastructure for Latin America',
  },
  {
    name: 'Virto Network',
    role: 'Protocol Engineering',
    href: 'https://virto.network',
    description: 'Decentralized commerce protocol built on Polkadot',
  },
  {
    name: 'Polkadot Fellowship',
    role: 'Proficient Member',
    href: 'https://polkadot.network',
    description: 'Core contributor to the Polkadot protocol governance',
  },
];
---

<div
  class="lg:col-span-5 bg-surface-container-high neobrutal-border neobrutal-shadow rounded-lg p-6"
>
  <div class="flex items-center gap-2 mb-6">
    <span class="material-symbols-outlined text-tertiary">handshake</span>
    <h2 class="font-mono text-xl font-bold text-on-surface">COLLABORATIONS</h2>
  </div>

  <div class="flex flex-col gap-3">
    {collaborations.map(({ name, role, href, description }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="group bg-surface-container border-2 border-outline-variant p-4 rounded flex items-center justify-between hover:border-primary transition-all hover:translate-x-0.5 hover:translate-y-0.5"
      >
        <div>
          <div class="font-mono text-lg font-bold text-on-surface group-hover:text-primary transition-colors">
            {name}
          </div>
          <div class="font-mono text-xs text-on-surface-variant mt-0.5">{role}</div>
          <div class="text-sm text-on-surface-variant mt-1 hidden group-hover:block">{description}</div>
        </div>
        <span class="material-symbols-outlined text-outline-variant group-hover:text-primary transition-colors shrink-0 ml-3">
          arrow_forward
        </span>
      </a>
    ))}
  </div>
</div>
