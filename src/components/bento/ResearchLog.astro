---
import { getPinnedRepos } from '../../lib/github';

const pinned = await getPinnedRepos('pandres95');

function repoYear(iso: string) {
  return new Date(iso).getFullYear();
}
---

<div
  class="lg:col-span-7 bg-surface-container neobrutal-border neobrutal-shadow rounded-lg p-6 flex flex-col"
>
  <div class="flex items-center gap-2 mb-6 border-b-2 border-outline-variant pb-2">
    <span class="material-symbols-outlined text-tertiary">science</span>
    <h2 class="font-mono text-xl font-bold text-on-surface">RESEARCH_&amp;_PRODUCTION</h2>
    <span class="ml-auto bg-surface-container-highest px-2 py-1 rounded neobrutal-border font-mono text-xs">
      ACADEMIC_LOG
    </span>
  </div>

  <div class="flex-grow flex flex-col gap-4">
    {pinned.map((repo) => (
      <article class="border-b-2 border-outline-variant pb-4 last:border-0 last:pb-0">
        <div class="flex justify-between items-start mb-2 gap-4">
          <a
            href={repo.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-lg font-semibold text-primary hover:underline leading-tight"
          >
            {repo.name}
          </a>
          <div class="flex items-center gap-2 shrink-0">
            {repo.stars > 0 && (
              <span class="font-mono text-xs text-tertiary flex items-center gap-0.5">
                <span class="material-symbols-outlined text-[12px]">star</span>
                {repo.stars}
              </span>
            )}
            <span class="font-mono text-sm text-tertiary">[{repoYear(repo.updatedAt)}]</span>
          </div>
        </div>
        {repo.description && (
          <p class="text-sm text-on-surface-variant mb-3 leading-relaxed">{repo.description}</p>
        )}
        <div class="flex flex-wrap gap-2">
          {repo.language && (
            <span class="border border-primary px-2 py-0.5 rounded font-mono text-[10px] text-primary uppercase">{repo.language}</span>
          )}
          {repo.topics.slice(0, 4).map((topic) => (
            <span class="border border-outline px-2 py-0.5 rounded font-mono text-[10px] text-on-surface uppercase">{topic}</span>
          ))}
        </div>
      </article>
    ))}

    {pinned.length === 0 && (
      <p class="text-sm text-on-surface-variant font-mono">No pinned repositories found.</p>
    )}
  </div>

  <a
    href="https://github.com/pandres95"
    target="_blank"
    rel="noopener noreferrer"
    class="mt-4 w-full bg-surface-container-highest neobrutal-border neobrutal-shadow-sm py-2 font-mono text-xs text-on-surface uppercase flex justify-center items-center gap-2 rounded hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition-all"
  >
    VIEW_FULL_ARCHIVE
    <span class="material-symbols-outlined text-[16px]">open_in_new</span>
  </a>
</div>
